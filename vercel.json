{
	"cleanUrls": true,
	"rewrites": [
		{
			"source": "/",
			"destination": "https://bpo-connect-backend.onrender.com/"
		},
		{
			"source": "/api/:path*",
			"destination": "https://bpo-connect-backend.onrender.com/api/:path*"
		},
		{
			"source": "/:path*",
			"destination": "https://bpo-connect-backend.onrender.com/:path*"
		}
	]
}
